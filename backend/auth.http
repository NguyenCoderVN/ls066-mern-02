  "password": "12345678",
  "username": "test3"
}


### POST Logout

POST {{base_url}}/api/auth/logout HTTP/1.1
Content-Type: application/json

{}


### GET me

GET {{base_url}}/api/auth/me HTTP/1.1
Cookie: jwt={{login.response.cookies.jwt.value}}
